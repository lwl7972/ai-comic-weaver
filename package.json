{"name":"ai-comic-weaver","version":"0.1.0","private":true,"description":"AI漫剧制作平台 - Electron桌面端","main":"electron/main.js","scripts":{"build:frontend":"cd frontend && npm ci && npm run build","build:backend":"cd backend && mvn clean package -DskipTests -q","build:all":"npm run build:frontend && npm run build:backend","pack:win":"npm run build:all && electron-builder --win --publish never","pack:mac":"npm run build:all && electron-builder --mac --publish never","dev":"cd frontend && npm run dev"},"devDependencies":{"electron":"^28.0.0","electron-builder":"^25.0.0"},"build":{"productName":"AI漫剧","appId":"com.aicomic.platform","directories":{"output":"release"},"files":["backend/target/*.jar","frontend/dist/**/*","electron/**/*","assets/**/*"],"win":{"target":[{"target":"nsis","arch":["x64"]}],"icon":"assets/logo.png"},"nsis":{"oneClick":false,"allowToChangeInstallationDirectory":true,"createDesktopShortcut":true}},"dependencies":{"electron-updater":"^6.8.9"}}